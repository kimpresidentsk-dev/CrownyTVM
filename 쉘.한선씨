// ═══════════════════════════════════════════════════════════════
// 크라우니OS 쉘 — 한선씨로 작성된 운영체계 터미널
//
// 순수 한선씨. Rust 코드 없음.
// 모든 시스템 기능은 한선씨 내장함수로 접근.
// ═══════════════════════════════════════════════════════════════

// ═══ 설정 ═══
변수 버전 = "0.1.0"
변수 실행중 = 1
변수 명령기록 = []

// ═══ 시작 배너 ═══
함수 배너() {
    출력값("")
    출력값("  ▲●▼◆ 크라우니OS v" + 버전 + " ▲●▼◆")
    출력값("  4세대 온톨로직 균형3진 체계")
    출력값("  한선씨로 작성된 운영체계 터미널")
    출력값("")
    출력값("  도움말: '도움' 입력")
    출력값("")
}

// ═══ 도움말 ═══
함수 도움말() {
    출력값("")
    출력값("  ═══ 크라우니OS 명령어 ═══")
    출력값("")
    출력값("  파일 시스템:")
    출력값("    목록 [경로]     — 디렉토리 내용 표시")
    출력값("    읽기 <파일>     — 파일 내용 표시")
    출력값("    쓰기 <파일> <내용> — 파일에 쓰기")
    출력값("    이동 <경로>     — 디렉토리 이동")
    출력값("    여기            — 현재 경로 표시")
    출력값("")
    출력값("  프로그래밍:")
    출력값("    실행 <파일.한선씨> — 한선씨 파일 실행")
    출력값("    평가 <코드>     — 한선씨 코드 직접 실행")
    출력값("")
    출력값("  시스템:")
    출력값("    정보            — 시스템 정보")
    출력값("    기록            — 명령 기록")
    출력값("    체계 <명령>     — 호스트 명령 실행")
    출력값("    도움            — 이 도움말")
    출력값("    끝              — 종료")
    출력값("")
}

// ═══ 경로 표시 포맷 ═══
함수 짧은경로() {
    변수 전체 = 현재경로()
    변수 홈 = 체계("echo $HOME")
    만약 (포함(전체, 홈) > 0) {
        변수 뒷부분 = 부분(전체, 글자수(홈), 글자수(전체))
        반환 "~" + 뒷부분
    }
    반환 전체
}

// ═══ 파일 크기 포맷 ═══
함수 파일정보(이름) {
    // 디렉토리인지 파일인지 표시
    변수 경로 = 현재경로() + "/" + 이름
    변수 정보 = 체계("stat -c '%s %F' '" + 경로 + "' 2>/dev/null || echo '? ?'")
    반환 정보
}

// ═══ 목록 명령 ═══
함수 명령_목록(인자) {
    변수 경로 = 인자
    만약 (글자수(경로) == 0) { 경로 = "." }
    변수 파일들 = 목록(경로)
    변수 수 = 길이(파일들)

    만약 (수 == 0) {
        출력값("  (비어 있음)")
        반환 0
    }

    변수 i = 0
    동안 (i < 수) {
        변수 이름 = 파일들[i]
        // 숨김 파일 건너뛰기
        만약 (글자수(이름) > 0) {
            만약 (글자(이름, 0) != ".") {
                변수 표시 = "  "
                // 디렉토리면 / 붙이기
                변수 전체 = 경로 + "/" + 이름
                만약 (파일존재(전체 + "/.") > 0) {
                    표시 = 표시 + "📁 " + 이름 + "/"
                } 아니면 {
                    // 한선씨 파일이면 특별 표시
                    만약 (포함(이름, ".한선씨") > 0) {
                        표시 = 표시 + "▲ " + 이름
                    } 아니면 {
                        표시 = 표시 + "  " + 이름
                    }
                }
                출력값(표시)
            }
        }
        i = i + 1
    }
    출력값("  — " + 문자열변환(수) + "개 항목")
}

// ═══ 읽기 명령 ═══
함수 명령_읽기(파일) {
    만약 (글자수(파일) == 0) {
        출력값("  사용법: 읽기 <파일>")
        반환 0
    }
    만약 (파일존재(파일) > 0) {
        변수 내용 = 읽기(파일)
        출력값(내용)
    } 아니면 {
        출력값("  ▼ 파일 없음: " + 파일)
    }
}

// ═══ 쓰기 명령 ═══
함수 명령_쓰기(파일, 내용) {
    만약 (글자수(파일) == 0) {
        출력값("  사용법: 쓰기 <파일> <내용>")
        반환 0
    }
    쓰기(파일, 내용)
    출력값("  ▲ 저장됨: " + 파일)
}

// ═══ 실행 명령 ═══
함수 명령_실행(파일) {
    만약 (글자수(파일) == 0) {
        출력값("  사용법: 실행 <파일.한선씨>")
        반환 0
    }
    만약 (파일존재(파일) > 0) {
        출력값("  ▲ 실행: " + 파일)
        변수 결과 = 체계("cd '" + 현재경로() + "' && 크라우니 '" + 파일 + "' 2>&1 || echo '한선씨 직접 실행 불가'")
        출력값(결과)
    } 아니면 {
        출력값("  ▼ 파일 없음: " + 파일)
    }
}

// ═══ 시스템 정보 ═══
함수 명령_정보() {
    출력값("")
    출력값("  ═══ 크라우니OS 시스템 정보 ═══")
    출력값("  버전: " + 버전)
    출력값("  경로: " + 현재경로())
    출력값("  언어: 한선씨 (ISA729 기반)")
    출력값("  VM:   삼진VM (균형3진 레지스터)")
    출력값("  인식: 4상 티옴타음 (▲●▼◆)")
    변수 시각 = 체계("date '+%Y-%m-%d %H:%M:%S'")
    출력값("  시각: " + 시각)
    변수 호스트 = 체계("hostname")
    출력값("  호스트: " + 호스트)
    출력값("  기록: " + 문자열변환(길이(명령기록)) + "개 명령")
    출력값("")
}

// ═══ 명령 파싱 ═══
함수 명령분리(줄) {
    // 첫 공백 기준으로 명령과 인자 분리
    변수 명령 = ""
    변수 인자 = ""
    변수 공백찾음 = 0
    변수 i = 0
    동안 (i < 글자수(줄)) {
        변수 c = 글자(줄, i)
        만약 (c == " " && 공백찾음 == 0) {
            공백찾음 = 1
        } 아니면 {
            만약 (공백찾음 == 0) {
                명령 = 명령 + c
            } 아니면 {
                인자 = 인자 + c
            }
        }
        i = i + 1
    }
    반환 [명령, 인자]
}

// ═══ 메인 루프 ═══
함수 메인() {
    배너()

    동안 (실행중 > 0) {
        변수 경로표시 = 짧은경로()
        변수 줄 = 입력("크라우니:" + 경로표시 + "▲ ")

        // 빈 줄
        만약 (글자수(줄) == 0) {
            // 무시
        } 아니면 {
            // 기록 저장
            명령기록 = 추가(명령기록, 줄)

            // 명령 파싱
            변수 분리 = 명령분리(줄)
            변수 명령 = 분리[0]
            변수 인자 = 분리[1]

            // 명령 실행
            만약 (명령 == "끝" || 명령 == "종료") {
                실행중 = 0
                출력값("  ▲●▼◆ 안녕히!")
            } 아니면 {
            만약 (명령 == "도움") {
                도움말()
            } 아니면 {
            만약 (명령 == "목록" || 명령 == "ㅁㄹ") {
                명령_목록(인자)
            } 아니면 {
            만약 (명령 == "읽기" || 명령 == "ㅇㄱ") {
                명령_읽기(인자)
            } 아니면 {
            만약 (명령 == "쓰기") {
                // 쓰기 파일 내용 → 인자에서 파일과 내용 분리
                변수 쓰기분리 = 명령분리(인자)
                명령_쓰기(쓰기분리[0], 쓰기분리[1])
            } 아니면 {
            만약 (명령 == "이동" || 명령 == "ㅇㄷ") {
                만약 (글자수(인자) > 0) {
                    만약 (경로변경(인자) > 0) {
                        출력값("  " + 현재경로())
                    } 아니면 {
                        출력값("  ▼ 경로 없음: " + 인자)
                    }
                }
            } 아니면 {
            만약 (명령 == "여기") {
                출력값("  " + 현재경로())
            } 아니면 {
            만약 (명령 == "실행") {
                명령_실행(인자)
            } 아니면 {
            만약 (명령 == "정보") {
                명령_정보()
            } 아니면 {
            만약 (명령 == "기록") {
                변수 i = 0
                동안 (i < 길이(명령기록)) {
                    출력값("  " + 문자열변환(i + 1) + ". " + 명령기록[i])
                    i = i + 1
                }
            } 아니면 {
            만약 (명령 == "체계") {
                변수 결과 = 체계(인자)
                출력값(결과)
            } 아니면 {
            만약 (명령 == "평가") {
                // 한선씨 코드 직접 평가 (현재는 체계 호출로)
                출력값("  (평가 기능은 추후 셀프호스팅 인터프리터 연결 예정)")
            } 아니면 {
                // 알 수 없는 명령 → 한선씨 파일인지 확인
                만약 (파일존재(명령) > 0 && 포함(명령, ".한선씨") > 0) {
                    명령_실행(명령)
                } 아니면 {
                    출력값("  ● 알 수 없는 명령: " + 명령)
                    출력값("    '도움' 으로 명령어 목록을 확인하세요")
                }
            }}}}}}}}}}}}
        }
    }
}

// ═══ 시작 ═══
메인()
