// ═══ 파일 처리 예제 ═══

// 파일에 기록
변수 경로 = "/tmp/크라우니_예제.txt"
쓰기(경로, "첫째줄: 크라우니 파일 시스템\n")
덧쓰기(경로, "둘째줄: 균형3진법 기반\n")
덧쓰기(경로, "셋째줄: 온톨로지 DB\n")

// 파일 읽기
변수 내용 = 읽기(경로)
출력값("=== 파일 내용 ===")
출력값(내용)

// 파일 존재 확인 (3진 결과)
변수 있나 = 파일존재(경로)
판정(있나) {
    양이면 { 출력값("▲ 파일 존재 확인") }
    중이면 { 출력값("● 불확실") }
    음이면 { 출력값("▼ 파일 없음") }
}

// 글자수 세기
변수 길이 = 글자수(내용)
출력값("글자수: ")
출력값(길이)

// 포함 여부
만약 (포함(내용, "균형3진법") > 0) {
    출력값("▲ '균형3진법' 문구 발견!")
}
