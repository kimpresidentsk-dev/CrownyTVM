// ═══════════════════════════════════════════════════════════════
// 셀프호스팅 시험 — 한선씨 안에서 한선씨를 실행
//
// 이 파일은 Rust VM 위에서 실행되지만,
// 한선씨실행() 함수는 한선씨로 작성된 컴파일러로
// 한선씨 코드를 해석하고 실행합니다.
//
// 즉: Rust VM → 한선씨 인터프리터 → 한선씨 프로그램
// ═══════════════════════════════════════════════════════════════

가져오기 "평가기.한선씨"

변수 통과 = 0
변수 전체 = 0

함수 검증(이름, 결과, 기대) {
    전체 = 전체 + 1
    만약 (문자열변환(결과) == 문자열변환(기대)) {
        출력값("  ✓ " + 이름)
        통과 = 통과 + 1
    } 아니면 {
        출력값("  ✗ " + 이름 + " — 기대:" + 문자열변환(기대) + " 실제:" + 문자열변환(결과))
    }
}

출력값("═══ 셀프호스팅 시험: 한선씨 안의 한선씨 ═══")
출력값("")

// ═══ 기본 산술 ═══
출력값("── 산술 ──")
검증("3+7", 한선씨실행("변수 r = 3 + 7"), 10)
검증("6*7", 한선씨실행("변수 r = 6 * 7"), 42)
검증("100-58", 한선씨실행("변수 r = 100 - 58"), 42)
검증("17%5", 한선씨실행("변수 r = 17 % 5"), 2)
검증("우선순위", 한선씨실행("변수 r = 3 + 7 * 2"), 17)

// ═══ 변수 ═══
출력값("")
출력값("── 변수 ──")
검증("선언", 한선씨실행("변수 x = 42"), 42)
검증("대입", 한선씨실행("변수 x = 10\nx = x + 5"), 15)

// ═══ 비교 ═══
출력값("")
출력값("── 비교 ──")
검증("5>3", 한선씨실행("변수 r = 5 > 3"), 1)
검증("3>5", 한선씨실행("변수 r = 3 > 5"), -1)
검증("5==5", 한선씨실행("변수 r = 5 == 5"), 1)

// ═══ 흐름 ═══
출력값("")
출력값("── 흐름 제어 ──")
검증("만약참", 한선씨실행("변수 r = 0\n만약 (1 > 0) { r = 42 }"), 42)
검증("만약거짓", 한선씨실행("변수 r = 0\n만약 (1 < 0) { r = 1 } 아니면 { r = 99 }"), 99)
검증("동안", 한선씨실행("변수 합 = 0\n변수 i = 0\n동안 (i < 5) { 합 = 합 + i\ni = i + 1 }"), 0)

// ═══ 함수 ═══
출력값("")
출력값("── 함수 ──")
검증("호출", 한선씨실행("함수 더하기(가, 나) { 반환 가 + 나 }\n변수 r = 더하기(3, 4)"), 7)
검증("중첩호출", 한선씨실행("함수 제곱(x) { 반환 x * x }\n변수 r = 제곱(제곱(3))"), 81)

출력값("")
출력값("═══ 결과: " + 문자열변환(통과) + "/" + 문자열변환(전체) + " 통과 ═══")
만약 (통과 == 전체) {
    출력값("▲●▼◆ 셀프호스팅 성공!")
}
