// ═══════════════════════════════════════════════════════════════
// CrownyFoundry — CrownyMind AI 연동
// 참조: 크라우니/체계/클로드.한선씨 (체계+curl 패턴)
//
// OpenClaw 포트: :18789(claude) :18790(gemini) :18791(sonnet)
// 폴백: 직접 Anthropic API (ANTHROPIC_API_KEY 환경변수)
// ═══════════════════════════════════════════════════════════════

변수 직접API키 = ""
변수 직접모델 = "claude-sonnet-4-6"

// ── OpenClaw 질의 ──
함수 OpenClaw질의(포트, 프롬프트) {
    쓰기("/tmp/.foundry_prompt.txt", 프롬프트)

    변수 json빌드 = 체계("python3 -c \"import json,sys; p=open('/tmp/.foundry_prompt.txt').read(); print(json.dumps({'prompt':p,'stream':False}))\" 2>/dev/null")

    만약 (글자수(json빌드) < 5) {
        반환 ""
    }

    쓰기("/tmp/.foundry_req.json", json빌드)

    변수 응답 = 체계("curl -s http://localhost:" + 포트 + "/v1/query -H 'Content-Type: application/json' -d @/tmp/.foundry_req.json 2>/dev/null")

    체계("rm -f /tmp/.foundry_prompt.txt /tmp/.foundry_req.json")

    반환 응답
}

// ── 직접 Anthropic API 폴백 ──
함수 직접API질의(프롬프트) {
    만약 (글자수(직접API키) < 10) {
        변수 환경키 = 체계("echo $ANTHROPIC_API_KEY")
        만약 (글자수(환경키) > 10) {
            직접API키 = 환경키
        } 아니면 {
            반환 "API키 없음"
        }
    }

    쓰기("/tmp/.foundry_msg.txt", 프롬프트)

    변수 json빌드 = 체계("python3 -c \"import json,sys; msg=open('/tmp/.foundry_msg.txt').read(); print(json.dumps({'model':'" + 직접모델 + "','max_tokens':1024,'messages':[{'role':'user','content':msg}]}))\" 2>/dev/null")

    쓰기("/tmp/.foundry_req.json", json빌드)

    변수 응답 = 체계("curl -s https://api.anthropic.com/v1/messages -H 'Content-Type: application/json' -H 'x-api-key: " + 직접API키 + "' -H 'anthropic-version: 2023-06-01' -d @/tmp/.foundry_req.json 2>/dev/null")

    체계("rm -f /tmp/.foundry_msg.txt /tmp/.foundry_req.json")

    반환 응답추출(응답)
}

// ── 응답 추출 (클로드.한선씨 패턴) ──
함수 응답추출(json) {
    변수 패턴 = "\"text\":\""
    변수 위치 = 0
    변수 i = 0
    동안 (i < 글자수(json) - 8) {
        만약 (부분(json, i, i + 8) == 패턴) {
            위치 = i + 8
            i = 글자수(json)
        }
        i = i + 1
    }
    만약 (위치 == 0) {
        반환 json
    }
    변수 결과 = ""
    변수 j = 위치
    변수 진행 = 1
    동안 (j < 글자수(json) 그리고 진행 > 0) {
        변수 c = 글자(json, j)
        만약 (c == "\\") {
            만약 (j + 1 < 글자수(json)) {
                변수 다음 = 글자(json, j + 1)
                만약 (다음 == "n") { 결과 = 결과 + "\n" }
                아니면 { 결과 = 결과 + 다음 }
                j = j + 2
            } 아니면 { j = j + 1 }
        } 아니면 {
            만약 (c == "\"") { 진행 = 0 }
            아니면 { 결과 = 결과 + c
                     j = j + 1 }
        }
    }
    반환 결과
}

// ═══ 통합 질의 (OpenClaw → 직접API 폴백 체인) ═══

함수 마인드질의(프롬프트) {
    // 1차: OpenClaw :18789 (claude)
    변수 응답1 = OpenClaw질의(18789, 프롬프트)
    만약 (글자수(응답1) > 5) { 반환 응답추출(응답1) }

    // 2차: OpenClaw :18790 (gemini)
    변수 응답2 = OpenClaw질의(18790, 프롬프트)
    만약 (글자수(응답2) > 5) { 반환 응답추출(응답2) }

    // 3차: OpenClaw :18791 (sonnet)
    변수 응답3 = OpenClaw질의(18791, 프롬프트)
    만약 (글자수(응답3) > 5) { 반환 응답추출(응답3) }

    // 4차: 직접 Anthropic API
    반환 직접API질의(프롬프트)
}

// ═══ 셀 컨텍스트 포함 질의 ═══

함수 셀해석(셀데이터, 질문) {
    변수 최종프롬프트 = "[셀컨텍스트]\n" + 셀데이터 + "\n\n질문: " + 질문
    반환 마인드질의(최종프롬프트)
}

// ═══ 파이프라인 AI 노드용 진입점 ═══

함수 AI노드실행(프롬프트, 데이터) {
    변수 최종 = 프롬프트 + "\n입력:\n" + 데이터
    반환 마인드질의(최종)
}
