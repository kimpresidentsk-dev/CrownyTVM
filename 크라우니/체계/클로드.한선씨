// 크라우니OS 클로드 AI 인터페이스
// 한선씨로 작성. 체계(curl) → Anthropic API.

변수 API키 = ""
변수 모델 = "claude-sonnet-4-20250514"
변수 대화목록 = []
변수 시스템메시지 = "당신은 크라우니OS AI 도우미입니다. 간결하게 답변하세요."

함수 키로드() {
    변수 환경키 = 체계("echo $ANTHROPIC_API_KEY")
    만약 (글자수(환경키) > 10) {
        API키 = 환경키
        반환 1
    }
    반환 -1
}

함수 응답추출(json) {
    // "text":" 패턴 찾기 → 내용 추출
    변수 패턴 = 부분("\"text\":\"", 0, 8)
    변수 위치 = 0
    변수 i = 0
    동안 (i < 글자수(json) - 8) {
        만약 (부분(json, i, i + 8) == 패턴) {
            위치 = i + 8
            i = 글자수(json)
        }
        i = i + 1
    }
    만약 (위치 == 0) {
        반환 "응답 파싱 실패: " + 부분(json, 0, 100)
    }
    // 닫는 " 찾기
    변수 결과 = ""
    변수 j = 위치
    변수 계속 = 1
    동안 (j < 글자수(json) && 계속 > 0) {
        변수 c = 글자(json, j)
        만약 (c == "\\") {
            만약 (j + 1 < 글자수(json)) {
                변수 다음 = 글자(json, j + 1)
                만약 (다음 == "n") {
                    결과 = 결과 + "\n"
                } 아니면 {
                    결과 = 결과 + 다음
                }
                j = j + 2
            } 아니면 {
                j = j + 1
            }
        } 아니면 {
            만약 (c == "\"") {
                계속 = 0
            } 아니면 {
                결과 = 결과 + c
                j = j + 1
            }
        }
    }
    반환 결과
}

함수 질문(메시지) {
    만약 (글자수(API키) < 10) {
        반환 "API 키가 없습니다. 키설정 <키> 로 설정하세요"
    }

    // JSON 요청 구성 (임시 파일 방식 — 이스케이프 회피)
    변수 메시지json = 메시지
    // 간단한 이스케이프: " → \"
    // 체계 명령으로 안전하게 처리
    쓰기("/tmp/.crowny_msg.txt", 메시지)
    쓰기("/tmp/.crowny_sys.txt", 시스템메시지)

    // jq나 python으로 안전한 JSON 구성
    변수 빌드 = 체계("python3 -c \"import json,sys; msg=open('/tmp/.crowny_msg.txt').read(); sys_msg=open('/tmp/.crowny_sys.txt').read(); print(json.dumps({'model':'" + 모델 + "','max_tokens':1024,'system':sys_msg,'messages':[{'role':'user','content':msg}]}))\" 2>/dev/null")

    만약 (글자수(빌드) < 10) {
        반환 "JSON 구성 실패"
    }

    쓰기("/tmp/.crowny_req.json", 빌드)

    변수 응답 = 체계("curl -s https://api.anthropic.com/v1/messages -H 'Content-Type: application/json' -H 'x-api-key: " + API키 + "' -H 'anthropic-version: 2023-06-01' -d @/tmp/.crowny_req.json 2>/dev/null")

    변수 텍스트 = 응답추출(응답)

    체계("rm -f /tmp/.crowny_msg.txt /tmp/.crowny_sys.txt /tmp/.crowny_req.json")

    반환 텍스트
}

함수 대화() {
    출력값("")
    출력값("  ▲●▼◆ 크라우니OS x 클로드 AI ▲●▼◆")
    출력값("  모델: " + 모델)
    만약 (키로드() < 0) {
        출력값("  ● API 키 필요. 키설정 <키> 로 설정하세요")
    } 아니면 {
        출력값("  ▲ API 키 로드됨")
    }
    출력값("  끝(종료), 초기화(리셋), 키설정 <키>")
    출력값("")

    변수 실행 = 1
    동안 (실행 > 0) {
        변수 줄 = 입력("나> ")
        만약 (글자수(줄) == 0) {
            // skip
        } 아니면 {
            만약 (줄 == "끝") {
                실행 = 0
            } 아니면 {
            만약 (줄 == "초기화") {
                대화목록 = []
                출력값("  (초기화됨)")
            } 아니면 {
                만약 (부분(줄, 0, 3) == "키설정") {
                    API키 = 부분(줄, 4, 글자수(줄))
                    출력값("  ▲ 키 설정됨")
                } 아니면 {
                    출력값("  (생각 중...)")
                    변수 답 = 질문(줄)
                    출력값("")
                    출력값("클로드> " + 답)
                    출력값("")
                }
            }}
        }
    }
}

함수 단일질문(메시지) {
    키로드()
    반환 질문(메시지)
}
