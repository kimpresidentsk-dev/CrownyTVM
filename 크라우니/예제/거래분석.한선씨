// ═══ KPS 트레이딩 시뮬레이션 (한선씨) ═══

// 시장 상태 주장
주장 시장 = ("BTC", "추세", "상승", 미확인)
주장 신호 = ("EMA9", "교차", "EMA21", 미확인)

// 근거 수집
근거(시장, "5분봉 EMA 정배열")
근거(신호, "골든크로스 발생")

// 인식상태 전이
전이(시장, 전진)
전이(신호, 전진)

// 3방향 판정으로 진입 결정
변수 시장점수 = 1   // 실제로는 결정점수 계산
변수 신호점수 = 1

판정(시장점수) {
    양이면 {
        판정(신호점수) {
            양이면 { 출력값("▲ KPS 진입 신호: 매수 실행") }
            중이면 { 출력값("● 신호 대기: 관찰 유지") }
            음이면 { 출력값("▼ 신호 부정: 진입 보류") }
        }
    }
    중이면 { 출력값("● 시장 미확정: 관찰") }
    음이면 { 출력값("▼ 시장 하락: 매수 금지") }
}

// 복리 계산
함수 복리계산(원금, 수익률, 횟수) {
    변수 결과 = 원금
    변수 i = 0
    동안 (i < 횟수) {
        결과 = 결과 + 결과 * 수익률 / 100
        i = i + 1
    }
    반환 결과
}

변수 최종 = 복리계산(1000, 66, 5)
출력값("5단계 복리 결과: ")
출력값(최종)

// 합의 연산 (3진 고유)
변수 분석1 = 티    // 분석가 A: 상승
변수 분석2 = 티    // 분석가 B: 상승
변수 분석3 = 타    // 분석가 C: 하락

변수 합의결과 = 분석1 ~~ 분석2
출력값("A~~B 합의: ")
출력값(합의결과)

변수 전체합의 = 합의결과 ~~ 분석3
출력값("전체 합의: ")
출력값(전체합의)
