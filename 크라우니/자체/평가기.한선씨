// ═══════════════════════════════════════════════════════════════
// 한선씨 평가기 — 한선씨로 작성 (트리워킹 인터프리터)
//
// AST를 직접 실행. 코드 생성 없이 즉시 평가.
// ═══════════════════════════════════════════════════════════════

가져오기 "구문.한선씨"

// ═══ 환경 (변수 저장소) ═══
// 환경 = [이름1, 값1, 이름2, 값2, ...] (짝수=이름, 홀수=값)
변수 환경 = []

함수 환경읽기(이름) {
    변수 i = 0
    동안 (i < 길이(환경)) {
        만약 (환경[i] == 이름) { 반환 환경[i + 1] }
        i = i + 2
    }
    반환 "미정의"
}

함수 환경쓰기(이름, 값) {
    변수 i = 0
    동안 (i < 길이(환경)) {
        만약 (환경[i] == 이름) {
            환경 = 설정(환경, i + 1, 값)
            반환 값
        }
        i = i + 2
    }
    환경 = 추가(환경, 이름)
    환경 = 추가(환경, 값)
    반환 값
}

// ═══ 평가 ═══

함수 평가(노드) {
    변수 종류 = 노드[0]

    만약 (종류 == "정수") { 반환 노드[1] }
    만약 (종류 == "실수") { 반환 노드[1] }
    만약 (종류 == "문자열") { 반환 노드[1] }

    만약 (종류 == "이름") {
        반환 환경읽기(노드[1])
    }

    만약 (종류 == "이항") {
        변수 연산 = 노드[1]
        변수 좌 = 평가(노드[2])
        변수 우 = 평가(노드[3])
        만약 (연산 == "+") { 반환 좌 + 우 }
        만약 (연산 == "-") { 반환 좌 - 우 }
        만약 (연산 == "*") { 반환 좌 * 우 }
        만약 (연산 == "/") { 반환 좌 / 우 }
        만약 (연산 == "%") { 반환 좌 % 우 }
        만약 (연산 == "==") { 만약 (좌 == 우) { 반환 1 } 반환 -1 }
        만약 (연산 == "!=") { 만약 (좌 != 우) { 반환 1 } 반환 -1 }
        만약 (연산 == ">") { 만약 (좌 > 우) { 반환 1 } 반환 -1 }
        만약 (연산 == "<") { 만약 (좌 < 우) { 반환 1 } 반환 -1 }
        만약 (연산 == ">=") { 만약 (좌 >= 우) { 반환 1 } 반환 -1 }
        만약 (연산 == "<=") { 만약 (좌 <= 우) { 반환 1 } 반환 -1 }
        반환 0
    }

    만약 (종류 == "단항") {
        변수 연산 = 노드[1]
        변수 값 = 평가(노드[2])
        만약 (연산 == "!") { 반환 0 - 값 }
        반환 값
    }

    만약 (종류 == "변수") {
        변수 값 = 평가(노드[2])
        환경쓰기(노드[1], 값)
        반환 값
    }

    만약 (종류 == "대입") {
        변수 값 = 평가(노드[2])
        환경쓰기(노드[1], 값)
        반환 값
    }

    만약 (종류 == "출력값") {
        변수 값 = 평가(노드[1])
        출력값(값)
        반환 값
    }

    만약 (종류 == "출력") {
        변수 값 = 평가(노드[1])
        출력(값)
        반환 값
    }

    만약 (종류 == "만약") {
        변수 조건 = 평가(노드[1])
        만약 (조건 > 0) {
            반환 평가(노드[2])
        } 아니면 {
            만약 (길이(노드[3]) > 0) {
                반환 평가(노드[3])
            }
        }
        반환 0
    }

    만약 (종류 == "동안") {
        동안 (평가(노드[1]) > 0) {
            평가(노드[2])
        }
        반환 0
    }

    만약 (종류 == "블록") {
        변수 결과 = 0
        변수 i = 1
        동안 (i < 길이(노드)) {
            결과 = 평가(노드[i])
            i = i + 1
        }
        반환 결과
    }

    만약 (종류 == "함수") {
        // 함수 정의: 환경에 AST 자체를 저장
        환경쓰기(노드[1], 노드)
        반환 0
    }

    만약 (종류 == "호출") {
        변수 이름 = 노드[1]
        변수 함수정보 = 환경읽기(이름)

        // 인자 평가
        변수 인자값들 = []
        변수 i = 2
        동안 (i < 길이(노드)) {
            인자값들 = 추가(인자값들, 평가(노드[i]))
            i = i + 1
        }

        // 환경 백업 + 인자 바인딩
        변수 이전환경 = 환경
        변수 인자이름 = 함수정보[2]
        변수 j = 0
        동안 (j < 길이(인자이름)) {
            환경쓰기(인자이름[j], 인자값들[j])
            j = j + 1
        }

        // 본문 실행
        변수 결과 = 평가(함수정보[3])
        환경 = 이전환경
        반환 결과
    }

    만약 (종류 == "반환") {
        반환 평가(노드[1])
    }

    반환 0
}

// ═══ 실행 진입점 ═══

함수 한선씨실행(원천코드) {
    환경 = []
    변수 토큰들 = 토큰화(원천코드)
    변수 구문나무 = 분석(토큰들)
    반환 평가(구문나무)
}
