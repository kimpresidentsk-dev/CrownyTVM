// ═══════════════════════════════════════════════════════════════
// 한선씨 읽개(렉서) — 한선씨로 작성
//
// 원천 코드 문자열 → 토큰 배열
// 토큰 = [종류, 값]
//   종류: "정수", "실수", "문자열", "이름", "연산자", "끝"
// ═══════════════════════════════════════════════════════════════

가져오기 "도구.한선씨"

함수 토큰화(원천) {
    변수 토큰들 = []
    변수 위치 = 0
    변수 전체 = 글자수(원천)

    동안 (위치 < 전체) {
        변수 c = 글자(원천, 위치)

        // 공백 건너뛰기
        만약 (공백인가(c) > 0) {
            위치 = 위치 + 1
        } 아니면 {
            // 주석: // 부터 줄끝
            만약 (c == "/" && 위치 + 1 < 전체 && 글자(원천, 위치 + 1) == "/") {
                동안 (위치 < 전체 && 글자(원천, 위치) != "\n") {
                    위치 = 위치 + 1
                }
            } 아니면 {
                // 문자열: "..."
                만약 (c == "\"") {
                    위치 = 위치 + 1
                    변수 내용 = ""
                    동안 (위치 < 전체 && 글자(원천, 위치) != "\"") {
                        내용 = 내용 + 글자(원천, 위치)
                        위치 = 위치 + 1
                    }
                    만약 (위치 < 전체) { 위치 = 위치 + 1 }
                    토큰들 = 추가(토큰들, 토큰("문자열", 내용))
                } 아니면 {
                    // 숫자
                    만약 (숫자인가(c) > 0) {
                        변수 숫자 = ""
                        동안 (위치 < 전체 && (숫자인가(글자(원천, 위치)) > 0 || 글자(원천, 위치) == ".")) {
                            숫자 = 숫자 + 글자(원천, 위치)
                            위치 = 위치 + 1
                        }
                        만약 (포함(숫자, ".") > 0) {
                            토큰들 = 추가(토큰들, 토큰("실수", 숫자))
                        } 아니면 {
                            토큰들 = 추가(토큰들, 토큰("정수", 숫자))
                        }
                    } 아니면 {
                        // 이름/키워드
                        만약 (글자인가(c) > 0) {
                            변수 이름 = ""
                            동안 (위치 < 전체 && (글자인가(글자(원천, 위치)) > 0 || 숫자인가(글자(원천, 위치)) > 0)) {
                                이름 = 이름 + 글자(원천, 위치)
                                위치 = 위치 + 1
                            }
                            토큰들 = 추가(토큰들, 토큰("이름", 이름))
                        } 아니면 {
                            // 2글자 연산자 체크
                            변수 다음 = ""
                            만약 (위치 + 1 < 전체) {
                                다음 = 글자(원천, 위치 + 1)
                            }
                            변수 이글자 = c + 다음
                            만약 (이글자 == "==" || 이글자 == "!=" || 이글자 == ">=" || 이글자 == "<=" || 이글자 == "&&" || 이글자 == "||" || 이글자 == "~~") {
                                토큰들 = 추가(토큰들, 토큰("연산자", 이글자))
                                위치 = 위치 + 2
                            } 아니면 {
                                // 1글자 연산자/구분자
                                토큰들 = 추가(토큰들, 토큰("연산자", c))
                                위치 = 위치 + 1
                            }
                        }
                    }
                }
            }
        }
    }

    토큰들 = 추가(토큰들, 토큰("끝", ""))
    반환 토큰들
}
