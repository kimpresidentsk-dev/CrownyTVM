// 한선씨 구문(파서) — 한선씨로 작성
//
// 토큰 배열 → AST (배열 기반 트리)
//
// AST 노드 = [종류, ...데이터]
//   ["정수", 값]
//   ["문자열", 값]
//   ["이름", 이름]
//   ["이항", 연산자, 좌, 우]
//   ["단항", 연산자, 대상]
//   ["변수", 이름, 값노드]
//   ["대입", 이름, 값노드]
//   ["만약", 조건, 참블록, 거짓블록]  (거짓=[] 이면 없음)
//   ["동안", 조건, 본문]
//   ["블록", 문장1, 문장2, ...]
//   ["함수", 이름, 인자배열, 본문]
//   ["호출", 이름, 인자1, 인자2, ...]
//   ["반환", 값]
//   ["출력값", 값]
// ═══════════════════════════════════════════════════════════════

가져오기 "읽개.한선씨"

// ═══ 파서 상태: 전역 변수 ═══
변수 파서토큰 = []
변수 파서위치 = 0

함수 파서현재() {
    만약 (파서위치 < 길이(파서토큰)) {
        반환 파서토큰[파서위치]
    }
    반환 토큰("끝", "")
}

함수 파서전진() {
    변수 t = 파서현재()
    파서위치 = 파서위치 + 1
    반환 t
}

함수 파서종류() { 반환 토큰종류(파서현재()) }
함수 파서값() { 반환 토큰값(파서현재()) }

함수 파서기대(종류, 값) {
    변수 t = 파서현재()
    만약 (토큰종류(t) == 종류 && 토큰값(t) == 값) {
        파서전진()
        반환 1
    }
    출력값("파서오류: 기대 " + 종류 + ":" + 값 + " 실제 " + 토큰종류(t) + ":" + 토큰값(t))
    반환 -1
}

// ═══ 분석 진입점 ═══

함수 분석(토큰들) {
    파서토큰 = 토큰들
    파서위치 = 0
    변수 문장들 = ["블록"]
    동안 (파서종류() != "끝") {
        문장들 = 추가(문장들, 문장분석())
    }
    반환 문장들
}

// ═══ 문장 ═══

함수 문장분석() {
    변수 값 = 파서값()

    만약 (값 == "변수") {
        파서전진()
        변수 이름 = 토큰값(파서전진())
        파서기대("연산자", "=")
        변수 식 = 표현식분석()
        반환 ["변수", 이름, 식]
    }

    만약 (값 == "함수") {
        파서전진()
        변수 이름 = 토큰값(파서전진())
        파서기대("연산자", "(")
        변수 인자 = []
        동안 (파서값() != ")") {
            인자 = 추가(인자, 토큰값(파서전진()))
            만약 (파서값() == ",") { 파서전진() }
        }
        파서기대("연산자", ")")
        변수 본문 = 블록분석()
        반환 ["함수", 이름, 인자, 본문]
    }

    만약 (값 == "만약") {
        파서전진()
        파서기대("연산자", "(")
        변수 조건 = 표현식분석()
        파서기대("연산자", ")")
        변수 참블록 = 블록분석()
        변수 거짓블록 = []
        만약 (파서값() == "아니면") {
            파서전진()
            거짓블록 = 블록분석()
        }
        반환 ["만약", 조건, 참블록, 거짓블록]
    }

    만약 (값 == "동안") {
        파서전진()
        파서기대("연산자", "(")
        변수 조건 = 표현식분석()
        파서기대("연산자", ")")
        변수 본문 = 블록분석()
        반환 ["동안", 조건, 본문]
    }

    만약 (값 == "반환") {
        파서전진()
        반환 ["반환", 표현식분석()]
    }

    만약 (값 == "출력값") {
        파서전진()
        파서기대("연산자", "(")
        변수 식 = 표현식분석()
        파서기대("연산자", ")")
        반환 ["출력값", 식]
    }

    만약 (값 == "출력") {
        파서전진()
        파서기대("연산자", "(")
        변수 식 = 표현식분석()
        파서기대("연산자", ")")
        반환 ["출력", 식]
    }

    // 이름: 대입 또는 호출 또는 표현식
    만약 (파서종류() == "이름") {
        변수 이름 = 토큰값(파서전진())
        만약 (파서값() == "=") {
            파서전진()
            반환 ["대입", 이름, 표현식분석()]
        }
        만약 (파서값() == "(") {
            파서전진()
            변수 인자 = ["호출", 이름]
            동안 (파서값() != ")") {
                인자 = 추가(인자, 표현식분석())
                만약 (파서값() == ",") { 파서전진() }
            }
            파서기대("연산자", ")")
            반환 인자
        }
        // 그냥 이름 (표현식의 일부)
        파서위치 = 파서위치 - 1
        반환 표현식분석()
    }

    반환 표현식분석()
}

// ═══ 블록 ═══

함수 블록분석() {
    파서기대("연산자", "{")
    변수 문장들 = ["블록"]
    동안 (파서값() != "}" && 파서종류() != "끝") {
        문장들 = 추가(문장들, 문장분석())
    }
    파서기대("연산자", "}")
    반환 문장들
}

// ═══ 표현식 (우선순위 등반) ═══

함수 표현식분석() { 반환 논리분석() }

함수 논리분석() {
    변수 좌 = 비교분석()
    동안 (파서값() == "&&" || 파서값() == "||" || 파서값() == "~~") {
        변수 연산 = 토큰값(파서전진())
        변수 우 = 비교분석()
        좌 = ["이항", 연산, 좌, 우]
    }
    반환 좌
}

함수 비교분석() {
    변수 좌 = 덧셈분석()
    동안 (파서값() == "==" || 파서값() == "!=" || 파서값() == ">" || 파서값() == "<" || 파서값() == ">=" || 파서값() == "<=") {
        변수 연산 = 토큰값(파서전진())
        변수 우 = 덧셈분석()
        좌 = ["이항", 연산, 좌, 우]
    }
    반환 좌
}

함수 덧셈분석() {
    변수 좌 = 곱셈분석()
    동안 (파서값() == "+" || 파서값() == "-") {
        변수 연산 = 토큰값(파서전진())
        변수 우 = 곱셈분석()
        좌 = ["이항", 연산, 좌, 우]
    }
    반환 좌
}

함수 곱셈분석() {
    변수 좌 = 원자분석()
    동안 (파서값() == "*" || 파서값() == "/" || 파서값() == "%") {
        변수 연산 = 토큰값(파서전진())
        변수 우 = 원자분석()
        좌 = ["이항", 연산, 좌, 우]
    }
    반환 좌
}

함수 원자분석() {
    변수 종류 = 파서종류()
    변수 값 = 파서값()

    만약 (종류 == "정수") {
        파서전진()
        반환 ["정수", 숫자변환(값)]
    }

    만약 (종류 == "실수") {
        파서전진()
        반환 ["실수", 숫자변환(값)]
    }

    만약 (종류 == "문자열") {
        파서전진()
        반환 ["문자열", 값]
    }

    만약 (종류 == "이름") {
        변수 이름 = 값
        파서전진()
        // 티/옴/타 리터럴
        만약 (이름 == "티" || 이름 == "참") { 반환 ["정수", 1] }
        만약 (이름 == "옴" || 이름 == "보류") { 반환 ["정수", 0] }
        만약 (이름 == "타" || 이름 == "거짓") { 반환 ["정수", -1] }
        // 함수 호출
        만약 (파서값() == "(") {
            파서전진()
            변수 인자 = ["호출", 이름]
            동안 (파서값() != ")") {
                인자 = 추가(인자, 표현식분석())
                만약 (파서값() == ",") { 파서전진() }
            }
            파서기대("연산자", ")")
            반환 인자
        }
        반환 ["이름", 이름]
    }

    // 괄호
    만약 (값 == "(") {
        파서전진()
        변수 식 = 표현식분석()
        파서기대("연산자", ")")
        반환 식
    }

    // 단항 부정
    만약 (값 == "!") {
        파서전진()
        반환 ["단항", "!", 원자분석()]
    }

    // 단항 마이너스
    만약 (값 == "-") {
        파서전진()
        반환 ["이항", "-", ["정수", 0], 원자분석()]
    }

    출력값("파서오류: 예상치 못한 " + 종류 + ":" + 값)
    파서전진()
    반환 ["정수", 0]
}
