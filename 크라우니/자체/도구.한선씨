// ═══ 글자 분류 ═══

함수 공백인가(c) {
    만약 (c == " ") { 반환 1 }
    만약 (c == "\n") { 반환 1 }
    만약 (c == "\t") { 반환 1 }
    반환 -1
}

함수 숫자인가(c) {
    만약 (c == "0") { 반환 1 }
    만약 (c == "1") { 반환 1 }
    만약 (c == "2") { 반환 1 }
    만약 (c == "3") { 반환 1 }
    만약 (c == "4") { 반환 1 }
    만약 (c == "5") { 반환 1 }
    만약 (c == "6") { 반환 1 }
    만약 (c == "7") { 반환 1 }
    만약 (c == "8") { 반환 1 }
    만약 (c == "9") { 반환 1 }
    반환 -1
}

함수 글자인가(c) {
    // 한글 범위: 가(0xAC00) ~ 힣(0xD7A3) — 포함으로 근사
    // 영문: 포함으로
    변수 영소 = "abcdefghijklmnopqrstuvwxyz"
    변수 영대 = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    만약 (포함(영소, c) > 0) { 반환 1 }
    만약 (포함(영대, c) > 0) { 반환 1 }
    만약 (c == "_") { 반환 1 }
    // 한글: 공백/숫자/연산자/구분자가 아닌 것 → 글자로 취급
    만약 (공백인가(c) > 0) { 반환 -1 }
    만약 (숫자인가(c) > 0) { 반환 -1 }
    만약 (포함("+-*/%=!><&|~(){}[],.\";", c) > 0) { 반환 -1 }
    // 나머지는 한글 등 식별자 글자
    반환 1
}

// ═══ 토큰 생성 ═══

함수 토큰(종류, 값) {
    반환 [종류, 값]
}

함수 토큰종류(t) { 반환 t[0] }
함수 토큰값(t) { 반환 t[1] }
