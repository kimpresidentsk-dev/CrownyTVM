가져오기 "isa729코드젠"
가져오기 "isa729vm"

변수 bc = isa729_컴파일("함수 팩(n) { 만약 (n < 2) { 반환 1 } 반환 n * 팩(n - 1) }\n출력(팩(5))")
변수 코드 = bc[0]
변수 풀 = bc[1]

출력("상수풀 길이: " + __내장__(30, 풀))
변수 pi = 0
동안 (pi < __내장__(30, 풀)) {
    출력("  풀[" + pi + "] = " + 풀[pi])
    pi = pi + 1
}

출력("")
출력("바이트코드 (" + __내장__(30, 코드) + "개):")
변수 i = 0
동안 (i < __내장__(30, 코드)) {
    변수 inst = 코드[i]
    출력("  " + i + ": [" + inst[0] + ", " + inst[1] + ", " + inst[2] + "]")
    i = i + 1
}
