// ═══════════════════════════════════════════════════════════════
// ISA729 풀 파이프라인 시험
// 한선씨 소스 → isa729_컴파일 → isa729_실행
// ═══════════════════════════════════════════════════════════════
가져오기 "isa729코드젠"
가져오기 "isa729vm"

출력("▲■▼ ISA729 풀 파이프라인 시험 ▲■▼")
출력("")

변수 ok = 0

// 헬퍼: isa729_실행은 [vm출력배열, 최종값]을 반환
// vm출력배열의 첫 번째 요소를 추출

// T1: 단순 산술
출력("── T1: 3 + 7 = 10 ──")
변수 bc1 = isa729_컴파일("출력(3 + 7)")
변수 r1 = isa729_실행(bc1[0], bc1[1])
변수 v1 = r1[0][0]
출력("  결과: " + v1)
만약 (v1 == "10") { 출력("  ✓")  ok = ok + 1 }
아니면 { 출력("  ✗ 기대: 10") }

// T2: 변수
출력("── T2: 변수 x = 6 * 7 ──")
변수 bc2 = isa729_컴파일("변수 x = 6 * 7\n출력(x)")
변수 r2 = isa729_실행(bc2[0], bc2[1])
변수 v2 = r2[0][0]
출력("  결과: " + v2)
만약 (v2 == "42") { 출력("  ✓")  ok = ok + 1 }
아니면 { 출력("  ✗ 기대: 42") }

// T3: 분기
출력("── T3: 만약 (5 > 3) ──")
변수 bc3 = isa729_컴파일("만약 (5 > 3) { 출력(42) } 아니면 { 출력(0) }")
변수 r3 = isa729_실행(bc3[0], bc3[1])
변수 v3 = r3[0][0]
출력("  결과: " + v3)
만약 (v3 == "42") { 출력("  ✓")  ok = ok + 1 }
아니면 { 출력("  ✗ 기대: 42") }

// T4: 루프 합산
출력("── T4: 루프 1~5 합 = 15 ──")
변수 bc4 = isa729_컴파일("변수 s = 0\n변수 i = 1\n동안 (i < 6) { s = s + i\ni = i + 1 }\n출력(s)")
변수 r4 = isa729_실행(bc4[0], bc4[1])
변수 v4 = r4[0][0]
출력("  결과: " + v4)
만약 (v4 == "15") { 출력("  ✓")  ok = ok + 1 }
아니면 { 출력("  ✗ 기대: 15") }

// T5: 함수 호출
출력("── T5: 함수 더하기(3,4) = 7 ──")
변수 bc5 = isa729_컴파일("함수 더하기(a, b) { 반환 a + b }\n출력(더하기(3, 4))")
변수 r5 = isa729_실행(bc5[0], bc5[1])
변수 v5 = r5[0][0]
출력("  결과: " + v5)
만약 (v5 == "7") { 출력("  ✓")  ok = ok + 1 }
아니면 { 출력("  ✗ 기대: 7") }

// T6: 재귀 팩토리얼
출력("── T6: 팩토리얼(5) = 120 ──")
변수 bc6 = isa729_컴파일("함수 팩(n) { 만약 (n < 2) { 반환 1 } 반환 n * 팩(n - 1) }\n출력(팩(5))")
변수 r6 = isa729_실행(bc6[0], bc6[1])
변수 v6 = r6[0][0]
출력("  결과: " + v6)
만약 (v6 == "120") { 출력("  ✓")  ok = ok + 1 }
아니면 { 출력("  ✗ 기대: 120") }

// 결과
출력("")
출력("══════════════════════════════════════════")
출력("ISA729 파이프라인 결과: " + ok + "/6 통과")
만약 (ok == 6) {
    출력("")
    출력("  한선씨 소스코드")
    출력("      ↓ isa729_컴파일()")
    출력("  ISA729 바이트코드 + 상수풀")
    출력("      ↓ isa729_실행()")
    출력("  ISA729 VM 실행 → 결과")
    출력("")
    출력("  ▲■▼ ISA729 풀 파이프라인 완성!")
}
출력("══════════════════════════════════════════")
