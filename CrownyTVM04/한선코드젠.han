// ═══════════════════════════════════════════════════════════════
// 한선코드젠 — 한선씨로 구현된 ISA729 바이트코드 생성기 (Stage 3)
// AST → [바이트코드, 상수풀]  (한선VM 호환)
// ═══════════════════════════════════════════════════════════════
가져오기 "한선렉서"

// ─── 컨텍스트: [code, consts, vnames, vslots, fnames, findices, nslot] ───
함수 _ctx새() { 반환 [[], [], [], [], [], [], 0] }

함수 _emit(ctx, op, a, b) {
    변수 c = ctx[0]
    c = c + [[op, a, b]]
    ctx[0] = c
    반환 ctx
}
함수 _emitz(ctx, op) { 반환 _emit(ctx, op, 0, 0) }
함수 _emita(ctx, op, a) { 반환 _emit(ctx, op, a, 0) }

함수 _addconst(ctx, v) {
    변수 idx = __내장__(30, ctx[1])
    변수 pool = ctx[1]
    pool = pool + [v]
    ctx[1] = pool
    반환 [ctx, idx]
}
함수 _pushint(ctx, v) {
    변수 r = _addconst(ctx, v)
    반환 _emita(r[0], 27, r[1])
}
함수 _pushstr(ctx, v) {
    변수 r = _addconst(ctx, v)
    반환 _emita(r[0], 27, r[1])
}
함수 _codelen(ctx) { 반환 __내장__(30, ctx[0]) }

// 패치: code[pc] = [op, newA, oldB]
함수 _patch(ctx, pc, a) {
    변수 code = ctx[0]
    변수 inst = code[pc]
    code[pc] = [inst[0], a, inst[2]]
    ctx[0] = code
    반환 ctx
}
함수 _patchb(ctx, pc, b) {
    변수 code = ctx[0]
    변수 inst = code[pc]
    code[pc] = [inst[0], inst[1], b]
    ctx[0] = code
    반환 ctx
}

// 변수 조회/선언
함수 _findvar(ctx, name) {
    변수 names = ctx[2]
    변수 slots = ctx[3]
    변수 i = __내장__(30, names) - 1
    동안 (i >= 0) {
        만약 (names[i] == name) { 반환 slots[i] }
        i = i - 1
    }
    반환 0 - 1
}
함수 _declvar(ctx, name) {
    변수 slot = ctx[6]
    변수 vn = ctx[2]
    변수 vs = ctx[3]
    vn = vn + [name]
    vs = vs + [slot]
    ctx[2] = vn
    ctx[3] = vs
    ctx[6] = slot + 1
    반환 [ctx, slot]
}
함수 _findfunc(ctx, name) {
    변수 fn_names = ctx[4]
    변수 fn_idx = ctx[5]
    변수 i = 0
    동안 (i < __내장__(30, fn_names)) {
        만약 (fn_names[i] == name) { 반환 fn_idx[i] }
        i = i + 1
    }
    반환 0 - 1
}

// ═══ 메인: AST → [코드, 상수풀] ═══

함수 코드생성(ast) {
    변수 ctx = _ctx새()

    // 1차: 함수 등록
    각각 node 에서 ast {
        만약 (node[0] == 23) {
            변수 r = _addconst(ctx, 0)
            ctx = r[0]
            변수 fnames = ctx[4]
            변수 fidxs = ctx[5]
            fnames = fnames + [node[1]]
            fidxs = fidxs + [r[1]]
            ctx[4] = fnames
            ctx[5] = fidxs
        }
    }

    // 2차: 코드 생성
    각각 node 에서 ast { ctx = _gen문장(ctx, node) }
    ctx = _emitz(ctx, 25)
    반환 [ctx[0], ctx[1]]
}

// ═══ 문장 생성 ═══

함수 _gen문장(ctx, node) {
    변수 t = node[0]

    만약 (t == 20) {
        ctx = _gen식(ctx, node[2])
        변수 r = _declvar(ctx, node[1])
        ctx = r[0]
        ctx = _emita(ctx, 34, r[1])
        반환 ctx
    }
    만약 (t == 21) {
        ctx = _gen식(ctx, node[2])
        변수 r = _declvar(ctx, node[1])
        ctx = r[0]
        ctx = _emita(ctx, 34, r[1])
        반환 ctx
    }
    만약 (t == 22) {
        ctx = _gen식(ctx, node[2])
        변수 slot = _findvar(ctx, node[1])
        ctx = _emita(ctx, 34, slot)
        반환 ctx
    }
    // 23=Fn
    만약 (t == 23) {
        변수 jmp_pc = _codelen(ctx)
        ctx = _emita(ctx, 18, 0)
        변수 func_pc = _codelen(ctx)
        변수 fi = _findfunc(ctx, node[1])
        만약 (fi >= 0) {
            변수 pool = ctx[1]
            pool[fi] = func_pc
            ctx[1] = pool
        }
        ctx = _emitz(ctx, 36)
        // 매개변수 스코프
        변수 saved_vn = ctx[2]
        변수 saved_vs = ctx[3]
        변수 saved_ns = ctx[6]
        ctx[2] = []
        ctx[3] = []
        ctx[6] = 0
        각각 param 에서 node[2] {
            변수 dr = _declvar(ctx, param)
            ctx = dr[0]
        }
        각각 stmt 에서 node[3] { ctx = _gen문장(ctx, stmt) }
        변수 body = node[3]
        변수 blen = __내장__(30, body)
        만약 (blen == 0) {
            ctx = _pushint(ctx, 0)
            ctx = _emitz(ctx, 21)
        } 혹시 (body[blen - 1][0] != 24) {
            ctx = _pushint(ctx, 0)
            ctx = _emitz(ctx, 21)
        }
        ctx[2] = saved_vn
        ctx[3] = saved_vs
        ctx[6] = saved_ns
        ctx = _patch(ctx, jmp_pc, _codelen(ctx))
        반환 ctx
    }
    만약 (t == 24) {
        만약 (node[1] == 0) { ctx = _pushint(ctx, 0) }
        아니면 { ctx = _gen식(ctx, node[1]) }
        ctx = _emitz(ctx, 21)
        반환 ctx
    }
    만약 (t == 25) {
        ctx = _gen식(ctx, node[1])
        ctx = _emitz(ctx, 7)
        변수 jf = _codelen(ctx)
        ctx = _emita(ctx, 19, 0)
        각각 s 에서 node[2] { ctx = _gen문장(ctx, s) }
        변수 je = _codelen(ctx)
        ctx = _emita(ctx, 18, 0)
        ctx = _patch(ctx, jf, _codelen(ctx))
        만약 (__내장__(30, node[3]) > 0) {
            각각 s 에서 node[3] { ctx = _gen문장(ctx, s) }
        }
        ctx = _patch(ctx, je, _codelen(ctx))
        반환 ctx
    }
    만약 (t == 26) {
        변수 ls = _codelen(ctx)
        ctx = _gen식(ctx, node[1])
        ctx = _emitz(ctx, 7)
        변수 jf = _codelen(ctx)
        ctx = _emita(ctx, 19, 0)
        각각 s 에서 node[2] { ctx = _gen문장(ctx, s) }
        ctx = _emita(ctx, 18, ls)
        ctx = _patch(ctx, jf, _codelen(ctx))
        반환 ctx
    }
    만약 (t == 28) {
        ctx = _gen식(ctx, node[1])
        ctx = _emitz(ctx, 32)
        반환 ctx
    }
    만약 (t == 29) {
        ctx = _gen식(ctx, node[1])
        반환 ctx
    }
    반환 ctx
}

// ═══ 표현식 생성 ═══

함수 _gen식(ctx, node) {
    변수 t = node[0]
    만약 (t == 1) { 반환 _pushint(ctx, node[1]) }
    만약 (t == 3) { 반환 _pushstr(ctx, node[1]) }
    만약 (t == 5) {
        만약 (node[1] == 1) { 반환 _emitz(ctx, 0) }
        만약 (node[1] == 0) { 반환 _emitz(ctx, 2) }
        반환 _emitz(ctx, 1)
    }
    만약 (t == 4) {
        변수 slot = _findvar(ctx, node[1])
        반환 _emita(ctx, 35, slot)
    }
    만약 (t == 10) {
        ctx = _gen식(ctx, node[2])
        ctx = _gen식(ctx, node[3])
        변수 op = node[1]
        만약 (op == "+")  { 반환 _emitz(ctx, 9) }
        만약 (op == "-")  { 반환 _emitz(ctx, 10) }
        만약 (op == "*")  { 반환 _emitz(ctx, 11) }
        만약 (op == "/")  { 반환 _emitz(ctx, 12) }
        만약 (op == "%")  { 반환 _emitz(ctx, 13) }
        만약 (op == "==") { 반환 _emitz(ctx, 3) }
        만약 (op == "!=") { 반환 _emitz(ctx, 4) }
        만약 (op == ">")  { 반환 _emitz(ctx, 5) }
        만약 (op == "<")  { 반환 _emitz(ctx, 6) }
        만약 (op == ">=") { ctx = _emitz(ctx, 6)  반환 _emitz(ctx, 7) }
        만약 (op == "<=") { ctx = _emitz(ctx, 5)  반환 _emitz(ctx, 7) }
        반환 ctx
    }
    만약 (t == 12) {
        각각 arg 에서 node[2] { ctx = _gen식(ctx, arg) }
        변수 fi = _findfunc(ctx, node[1])
        만약 (fi >= 0) {
            ctx = _emita(ctx, 27, fi)
            ctx = _emita(ctx, 20, __내장__(30, node[2]))
        }
        반환 ctx
    }
    만약 (t == 40) {
        각각 elem 에서 node[1] { ctx = _gen식(ctx, elem) }
        ctx = _emita(ctx, 63, __내장__(30, node[1]))
        반환 ctx
    }
    반환 ctx
}

// ═══ 통합 ═══
함수 컴파일(소스) {
    변수 토큰들 = 렉싱(소스)
    변수 ast = 파싱(토큰들)
    반환 코드생성(ast)
}
